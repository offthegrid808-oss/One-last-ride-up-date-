<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>One Last Ride Customs</title>
  <style>
    body { margin: 0; font-family: Arial, sans-serif; background-color: #0d0d0d; color: #f2f2f2; }
    a { color: #e10600; text-decoration: none; }
    h1, h2, h3 { margin: 0; }
    section { padding: 50px 20px; max-width: 1200px; margin: auto; }

    /* Hero */
    .hero {
      background: url('https://images.unsplash.com/photo-1596495577886-cd4e828c172f?auto=format&fit=crop&w=1500&q=80') center/cover no-repeat;
      height: 80vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      color: #f2f2f2;
    }
    .hero h1 { font-size: 2.8rem; color: #e10600; margin-bottom: 15px; }
    .hero p { font-size: 1.2rem; margin-bottom: 20px; }
    .hero .btn { background-color: #e10600; color: #fff; padding: 12px 25px; margin: 5px; border: none; cursor: pointer; font-size: 1rem; transition: 0.3s; }
    .hero .btn:hover { background-color: #a10000; }

    /* Services */
    .services { display: grid; grid-template-columns: repeat(auto-fit,minmax(250px,1fr)); gap: 20px; margin-top: 30px; }
    .service-card { background-color: #1a1a1a; padding: 20px; border-radius: 10px; }
    .service-card h3 { color: #e10600; margin-bottom: 10px; }

    /* Gallery */
    .gallery { display: grid; grid-template-columns: repeat(auto-fit,minmax(200px,1fr)); gap: 10px; margin-top: 20px; }
    .gallery img { width: 100%; border-radius: 10px; }

    /* Contact */
    .contact form { display: flex; flex-direction: column; max-width: 500px; margin: auto; }
    .contact input, .contact textarea { margin: 10px 0; padding: 10px; border-radius: 5px; border: none; }
    .contact button { background-color: #e10600; color: #fff; padding: 12px; border: none; border-radius: 5px; cursor: pointer; font-size: 1rem; transition: 0.3s; }
    .contact button:hover { background-color: #a10000; }

    /* Footer */
    footer { text-align: center; padding: 20px; background-color: #1a1a1a; margin-top: 50px; }

    /* AI Chat */
    #aiChat { position: fixed; bottom: 20px; right: 20px; background-color: #e10600; color: #fff; padding: 15px; border-radius: 50%; cursor: pointer; font-weight: bold; z-index: 1000; }
    #aiWindow { display: none; position: fixed; bottom: 70px; right: 20px; width: 280px; background-color: #1a1a1a; color: #f2f2f2; border-radius: 10px; padding: 15px; z-index: 1000; font-size: 0.9rem; }
    #aiWindow p { margin: 8px 0; }
  </style>
</head>
<body>

  <!-- Hero -->
  <section class="hero">
    <h1>Motorcycle Repairs, Maintenance, Paint & Custom Builds for All Bikes</h1>
    <p>One Last Ride Customs handles everything from repairs to custom builds, parts, and paint across Western Massachusetts.</p>
    <button class="btn" onclick="scrollToContact()">Schedule Service</button>
    <button class="btn" onclick="callShop()">Call the Shop</button>
  </section>

  <!-- Services -->
  <section>
    <h2 style="text-align:center; color:#e10600;">Our Services</h2>
    <div class="services">
      <div class="service-card">
        <h3>Repairs & Maintenance</h3>
        <p>All types of motorcycles. Diagnostics, tune-ups, oils, tires, and more.</p>
      </div>
      <div class="service-card">
        <h3>Used Parts & Supplies</h3>
        <p>Used parts available, plus new tires, oils, and consumables for every bike.</p>
      </div>
      <div class="service-card">
        <h3>Custom Builds & Fabrication</h3>
        <p>One-of-a-kind builds, modifications, and metal work to make your bike unique.</p>
      </div>
      <div class="service-card">
        <h3>Paint & Restoration</h3>
        <p>Custom paint jobs, tank refinishing, and full motorcycle restorations.</p>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section>
    <h2 style="text-align:center; color:#e10600;">Gallery</h2>
    <div class="gallery">
      <img src="https://images.unsplash.com/photo-1596495577886-cd4e828c172f?auto=format&fit=crop&w=800&q=80" alt="Motorcycle 1">
      <img src="https://images.unsplash.com/photo-1596495577886-cd4e828c172f?auto=format&fit=crop&w=801&q=80" alt="Motorcycle 2">
      <img src="https://images.unsplash.com/photo-1596495577886-cd4e828c172f?auto=format&fit=crop&w=802&q=80" alt="Motorcycle 3">
      <img src="https://images.unsplash.com/photo-1596495577886-cd4e828c172f?auto=format&fit=crop&w=803&q=80" alt="Motorcycle 4">
      <img src="https://images.unsplash.com/photo-1596495577886-cd4e828c172f?auto=format&fit=crop&w=804&q=80" alt="Motorcycle 5">
      <img src="https://images.unsplash.com/photo-1596495577886-cd4e828c172f?auto=format&fit=crop&w=805&q=80" alt="Motorcycle 6">
    </div>
  </section>

  <!-- Contact -->
  <section class="contact" id="contact">
    <h2 style="text-align:center; color:#e10600;">Contact Us</h2>
    <form onsubmit="alert('Message sent!'); return false;">
      <input type="text" placeholder="Your Name" required>
      <input type="email" placeholder="Your Email" required>
      <textarea placeholder="Message" rows="5" required></textarea>
      <button type="submit">Send Message</button>
    </form>
    <p style="text-align:center;">📍 510 New Ludlow Rd, South Hadley, MA 01075<br>📞 413-409-7921<br>📧 onelastridecustoms@gmail.com</p>
  </section>

  <!-- Footer -->
  <footer>
    &copy; 2026 One Last Ride Customs
  </footer>

  <!-- AI Assistant -->
  <div id="aiChat" onclick="toggleAI()">AI</div>
  <div id="aiWindow">
    <p><strong>One Last Ride Customs Assistant</strong></p>
    <p>We handle repairs, tune-ups, oils, tires, parts & custom builds.</p>
    <p>Call us: 413-409-7921</p>
    <p>Email: onelastridecustoms@gmail.com</p>
    <p>Ask me a question!</p>
  </div>

  <script>
    function scrollToContact() { document.getElementById('contact').scrollIntoView({ behavior: 'smooth' }); }
    function callShop() { window.location.href = "tel:4134097921"; }
    function toggleAI() { const ai = document.getElementById('aiWindow'); ai.style.display = (ai.style.display==='block')?'none':'block'; }
  </script>

</body>
</html>
